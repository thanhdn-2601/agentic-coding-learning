#----------------------------------------------------------
# Supabase Local Development Environment Variables
#   Google OAuth (for local development)
#   Get these from https://console.cloud.google.com/apis/credentials
#----------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
SUPABASE_EXTRA_SEEDS=./seeds/dev/*.sql

#----------------------------------------------------------
# Client Environment Variables
#----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://project_id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Event date-time in ISO-8601 format (e.g. 2026-04-18T18:30:00+07:00)
NEXT_PUBLIC_EVENT_DATETIME=2026-04-18T18:30:00+07:00

#----------------------------------------------------------
# Server Environment Variables
#----------------------------------------------------------
SUPABASE_SECRET_KEY=your_supabase_secret_key
